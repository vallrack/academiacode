rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helpers de Autenticación y Rol ---
    function isSignedIn() {
      return request.auth != null;
    }

    function getRole() {
      return request.auth.token.get('role', null);
    }

    // Usando los nombres de rol actualizados
    function isAdmin() {
      return isSignedIn() && getRole() == 'Super Admin';
    }

    function isTeacher() {
      return isSignedIn() && getRole() == 'Profesor';
    }

    function isStudent() {
      return isSignedIn() && getRole() == 'Estudiante';
    }

    // --- Usuarios ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // --- Grupos ---
    match /groups/{groupId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update, delete: if isAdmin() || isTeacher();
    }
    
    // --- Cursos ---
    match /courses/{courseId} {
      allow read, list: if isSignedIn();
      allow create, update, delete: if isTeacher() || isAdmin();
    }
    
    // --- Módulos (REGLA CORREGIDA A NIVEL RAÍZ) ---
    match /modules/{moduleId} {
      allow read, list: if isSignedIn();
      allow create, update, delete: if isTeacher() || isAdmin();
    }
    
    // --- Lecciones (REGLA CORREGIDA A NIVEL RAÍZ) ---
    match /lessons/{lessonId} {
      allow read, list: if isSignedIn();
      allow create, update, delete: if isTeacher() || isAdmin();
    }

    // --- Asignaciones ---
    match /assignments/{assignmentId} {
      allow read, list: if isSignedIn();
      allow create: if isTeacher() || isAdmin();
      allow update: if isTeacher() || isAdmin();
      allow delete: if isAdmin();
    }

    // --- Desafíos ---
    match /challenges/{challengeId} {
      allow read: if isSignedIn();
      allow create: if isTeacher() || isAdmin();
      allow update: if isTeacher() || isAdmin();
      allow delete: if isAdmin();
    }

    // --- Submissions (Resultados) ---
    match /submissions/{submissionId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAdmin() || isTeacher();
      allow delete: if isAdmin();
    }
  }
}
